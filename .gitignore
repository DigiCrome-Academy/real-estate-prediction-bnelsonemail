# Ignore Quarto output files
_reports/            # Directory where the final PDF report is saved
*.html               # HTML files generated by Quarto
*.pdf                # Ignore generated PDFs if they are in a specific output folder
*.docx               # If you're generating Word documents
*.tex                # Temporary LaTeX files generated by Quarto

# Ignore Quarto cache and temporary files
.quarto/             # Quarto's cache directory
_cache/              # Cache folder that Quarto uses for intermediate files

# Ignore generated technical report outputs
technical_report/reports/
technical_report/report_files/
technical_report/*_files/
technical_report/.quarto/
technical_report/_cache/
technical_report/*.html
technical_report/*.pdf
technical_report/*.docx
technical_report/*.tex
